{
  "name": "Garmin Badge Database",
  "description": "Sync your badge and challenge data from Garmin Connect",
  "version": "2.0.7",
  "manifest_version": 3,
  "homepage_url": "https://garminbadges.com",
  "permissions": [
    "storage",
    "scripting",
    "activeTab"
  ],
  "host_permissions": [
    "*://connect.garmin.com/*",
    "https://api.garminbadges.com/api/*",
    "http://localhost/api/*",
    "http://localhost:*/api/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "/images/icon_16.png",
      "32": "/images/icon_32.png",
      "48": "/images/icon_48.png",
      "128": "/images/icon_128.png"
    }
  },
  "icons": {
    "16": "/images/icon_16.png",
    "32": "/images/icon_32.png",
    "48": "/images/icon_48.png",
    "128": "/images/icon_128.png"
  },
  "options_ui": {
    "page": "options.html",
    "open_in_tab": false
  }
}
